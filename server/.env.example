# Server Configuration
PORT=5000
NODE_ENV=development

# Database
MONGODB_URI=mongodb://localhost:27017/shopguard

# JWT Secret
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# TikTok Shop API Credentials
TIKTOK_APP_KEY=your-tiktok-app-key
TIKTOK_APP_SECRET=your-tiktok-app-secret
TIKTOK_API_BASE_URL=https://open-api.tiktokglobalshop.com

# Email Configuration (for alerts)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Alert Thresholds
LATE_DISPATCH_THRESHOLD=4.0
ACCOUNT_HEALTH_CRITICAL=400
VTR_MINIMUM=95.0
ON_TIME_DELIVERY_TARGET=95.0

# Monitoring Intervals (in minutes)
METRICS_CHECK_INTERVAL=5
ALERT_CHECK_INTERVAL=10

# Frontend URL (Stripe redirects, TikTok OAuth return)
FRONTEND_URL=http://localhost:5173

# Stripe Billing (USA SaaS)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_ID=price_...

# TikTok OAuth redirect (must match Developer Portal)
TIKTOK_REDIRECT_URI=http://localhost:5000/api/tiktok/callback

# Supabase (optional sync with profiles RLS)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Creador: acceso total sin pagar (tu email al registrarte)
CREATOR_EMAILS=sylai.tech@gmail.com
